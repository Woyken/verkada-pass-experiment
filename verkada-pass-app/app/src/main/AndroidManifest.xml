<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application
        android:name=".VerkadaPassApplication"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.VerkadaPass">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.VerkadaPass">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.VerkadaPass">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <activity
            android:name=".widget.TileSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.VerkadaPass" />

        <receiver
            android:name=".widget.DoorWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.woyken.verkadapass.ACTION_UNLOCK" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_door_info" />
        </receiver>

        <service
            android:name=".widget.DoorTile1"
            android:exported="true"
            android:label="Door Tile 1"
            android:icon="@drawable/ic_tile_lock"
            android:foregroundServiceType="shortService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data android:name="android.service.quicksettings.TOGGLEABLE_TILE" android:value="false" />
        </service>

        <service
            android:name=".widget.DoorTile2"
            android:exported="true"
            android:label="Door Tile 2"
            android:icon="@drawable/ic_tile_lock"
            android:foregroundServiceType="shortService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data android:name="android.service.quicksettings.TOGGLEABLE_TILE" android:value="false" />
        </service>

        <service
            android:name=".widget.DoorTile3"
            android:exported="true"
            android:label="Door Tile 3"
            android:icon="@drawable/ic_tile_lock"
            android:foregroundServiceType="shortService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data android:name="android.service.quicksettings.TOGGLEABLE_TILE" android:value="false" />
        </service>

        <service
            android:name=".widget.DoorTile4"
            android:exported="true"
            android:label="Door Tile 4"
            android:icon="@drawable/ic_tile_lock"
            android:foregroundServiceType="shortService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data android:name="android.service.quicksettings.TOGGLEABLE_TILE" android:value="false" />
        </service>

        <service
            android:name=".widget.UnlockForegroundService"
            android:exported="false"
            android:foregroundServiceType="shortService" />
    </application>

</manifest>
